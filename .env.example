# Agent Overseas Report local configuration template.
# Copy to .env for local development. Do not commit .env or real secrets.

# Runtime
APP_ENV=local
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s %(levelname)s %(name)s - %(message)s

# SQLite database. Keep the sqlite:/// prefix.
OVERSEAS_REPORT_DATABASE_URL=sqlite:///.data/overseas_report.sqlite3

# DeepSeek (OpenAI-compatible). Leave the key empty to use the local demo LLM.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=60

# Embedding/RAG configuration. The default provider is a deterministic local hashing embedder.
EMBEDDING_PROVIDER=local_hashing
EMBEDDING_MODEL=hashing-ngram-v1
EMBEDDING_DIMENSIONS=384
KNOWLEDGE_BASE_STORAGE_DIR=.data/knowledge_base_uploads
KNOWLEDGE_BASE_VECTOR_DIR=.data/knowledge_base_vectors

# Optional orchestration and research feature flags.
ENABLE_CREWAI=false
CREWAI_VERBOSE=false
ENABLE_WEB_RESEARCH=false

# Knowledge-base upload security.
MAX_UPLOAD_BYTES=20971520
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.docx,.xlsx,.pptx,.md,.txt
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.openxmlformats-officedocument.presentationml.presentation,text/markdown,text/plain
